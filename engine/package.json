{
  "name": "beacon-engine",
  "version": "1.0.0",
  "private": true,
  "description": "Beacon — US-IP website monitoring engine for commercial signage sites",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "check:once": "tsx src/index.ts --once",
    "check:one": "tsx src/index.ts --once --one-site --one-profile",
    "form:once": "tsx src/index.ts --form-once",
    "form:one": "tsx src/index.ts --form-once --one-site --headed",
    "detect:forms": "tsx src/index.ts --detect-forms",
    "report:daily": "tsx src/index.ts --daily-report",
    "scheduler": "tsx src/scheduler.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "dotenv": "^16.4.7",
    "imapflow": "^1.0.181",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.0",
    "playwright": "^1.50.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
