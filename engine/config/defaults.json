{
  "loadCheckIntervalMinutes": 30,
  "formTestTimesEastern": ["00:00", "06:00", "12:00", "18:00"],
  "dailyReportTimeEastern": "23:30",
  "loadTimeThresholdMs": 8000,
  "consecutiveSlowChecksBeforeAlert": 2,
  "alertCooldownHours": 2,
  "formLayer1TimeoutSeconds": 15,
  "formLayer2TimeoutMinutes": 10,
  "screenshotRetentionDays": 30,
  "monitorQueryParam": "monitor=1",
  "testIdentity": {
    "name": "MONITOR TEST",
    "email": "monitor@example.com",
    "phone": "5550100100",
    "messageTemplate": "Automated monitoring test - please ignore. Run ID: {runId}"
  },
  "formInboxVerificationEnabled": false,
  "profiles": {
    "desktop": {
      "browser": "chromium",
      "viewport": { "width": 1920, "height": 1080 }
    },
    "webkit": {
      "browser": "webkit",
      "viewport": { "width": 1440, "height": 900 }
    },
    "mobile": {
      "browser": "chromium",
      "device": "iPhone 14"
    }
  },
  "geoCheckUrl": "https://cloudflare.com/cdn-cgi/trace",
  "requiredCountry": "US",
  "delayMsBetweenChecks": 18000,
  "delayMsBetweenProfiles": 45000,
  "delayMsAfterRateLimit": 60000,
  "gotoMaxAttempts": 2,
  "deploymentMode": "staging",
  "stagingLabel": "Local NON-US test",
  "skipAlertsInStaging": true
}
