# ============================================================
# Beacon engine — LOCAL DEVELOPMENT ONLY
# Copy to .env on your PC. Never commit .env.
# Production secrets live ONLY in GitHub Actions Secrets.
# ============================================================

# staging = local / Pakistan tuning | production = GitHub Actions only
DEPLOYMENT_MODE=staging

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Set true ONLY in GitHub Actions (already set in the workflow files)
FORCE_PRODUCTION=false

# Optional: US residential proxy later. Leave empty for direct GitHub runner IP.
# PROXY_URL=

# Email alerts + daily report
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
ALERT_TO=your-email@gmail.com
REPORT_TO=your-email@gmail.com
RESEND_API_KEY=

# Form test identity
TEST_NAME=amaz@beacon
TEST_EMAIL=amaz@beacon.com
TEST_PHONE=5550100100

# Optional: inbox verification (Layer 2)
# FORM_INBOX_VERIFICATION=true
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=...
# IMAP_PASS=...
