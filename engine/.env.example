# Engine — local only. Production values live in GitHub Actions Secrets.

DEPLOYMENT_MODE=staging
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
FORCE_PRODUCTION=false

# Optional residential proxy (reduces HTTP 429 from GitHub datacenter IPs).
# Prefer: http://USERNAME:PASSWORD@host:port
# PROXY_URL=
# PROXY_USERNAME=
# PROXY_PASSWORD=
